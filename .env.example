# ============================================
# Kenzy Store Backend — Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for demo — file-based, no setup needed)
DATABASE_URL="file:./dev.db"

# JWT Secrets (WAJIB diganti di production!)
JWT_ACCESS_SECRET=kenzy-access-secret-change-me-in-production
JWT_REFRESH_SECRET=kenzy-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
