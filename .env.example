# ============================================
# Kenzy Store Backend — Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for demo — file-based, no setup needed)
DATABASE_URL="file:./dev.db"

# JWT Secrets (WAJIB diganti di production!)
JWT_ACCESS_SECRET=kenzy-access-secret-change-me-in-production
JWT_REFRESH_SECRET=kenzy-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# CORS Whitelist — strict origin untuk security.js (comma-separated)
ALLOWED_ORIGINS=https://kenzytopup-frontenddddd-ctiblgjlu-apal4ahs-projects.vercel.app,http://localhost:5173

# WhatsApp Gateway (Fonnte)
FONNTE_TOKEN=isi_token_dari_dashboard_fonnte

# Admin WA Number (untuk notifikasi order masuk & OTP 2FA)
ADMIN_WA_NUMBER=6282395928309

# Website URL (untuk link di notifikasi)
WEBSITE_URL=https://kenzytopup-frontenddddd-ctiblgjlu-apal4ahs-projects.vercel.app

# Web Push Notification (VAPID)
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=isi_vapid_public_key_disini
VAPID_PRIVATE_KEY=isi_vapid_private_key_disini
VAPID_MAILTO=mailto:admin@kenzystore.com
