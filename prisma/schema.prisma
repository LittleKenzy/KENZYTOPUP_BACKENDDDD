// ============================================
// Prisma Schema — Kenzy Store
// Database: PostgreSQL (Supabase)
// ============================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String   @unique
  password   String   // bcrypt hashed
  role       String   @default("user") // "user" | "admin"
  waVerified Boolean  @default(true)   // Apakah nomor WA terverifikasi (untuk blast)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transactions       Transaction[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  loyaltyPoints      LoyaltyPoints?
  pointRedemptions   PointRedemption[]
  missionLogs        MissionLog[]
  blastLogs          BlastLog[]
  waBlastsSent       WaBlast[]          // Custom blast campaigns yang dibuat admin ini
  pushSubscriptions  PushSubscription[] // Web push notification subscriptions
  notifications      Notification[]     // In-app notifications
  otpSessions        OtpSession[]       // 2FA OTP sessions untuk login admin
  userCards          UserCard[]         // Kartu kolektibel yang dimiliki user
  gamerProfiles      GamerProfile[]     // Profil game user (1 per game)
  wishlist           Wishlist[]         // Kartu yang diinginkan user
  tradeOffers        TradeOffer[] @relation("TradeOfferer")  // Trade yang dibuat user
  tradeMatches       TradeOffer[] @relation("TradeMatched")  // Trade yang di-match ke user
}

// ─── OTP SESSION (2FA Admin Login) ──────────
// Menyimpan OTP session saat admin login dengan 2FA
// OTP dikirim ke WA owner, admin harus input OTP untuk dapat JWT
model OtpSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique  // Random UUID, identifier sesi OTP (dikirim ke frontend)
  hashedOtp    String             // OTP yang sudah di-hash bcrypt (TIDAK simpan plain)
  adminId      String             // Admin yang sedang login
  attempts     Int      @default(0) // Counter percobaan salah (max 3)
  expiresAt    DateTime           // Waktu kadaluarsa (now + 5 menit)
  createdAt    DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

// ─── PRODUCT ─────────────────────────────────
// category: GAME | EWALLET | PLN | PULSA | PAKET_DATA
model Product {
  id           String   @id @default(uuid())
  category     String   // GAME, EWALLET, PLN, PULSA, PAKET_DATA
  name         String
  description  String?
  denomination String   // nominal label, e.g. "86 Diamonds", "50.000"
  price        Int      // harga dalam rupiah (integer, no float)
  operatorCode String   // kode operator / publisher, e.g. "MLBB", "TELKOMSEL"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  transactions Transaction[]
  flashSales   FlashSale[]
}

// ─── TRANSACTION ─────────────────────────────
// status: PENDING | SUCCESS | FAILED
// paymentMethod: CASH | QRIS | DANA | SHOPEEPAY
model Transaction {
  id            String   @id @default(uuid())
  userId        String
  productId     String
  targetId      String   // ID game / no HP / no meter PLN
  amount        Int      // jumlah dibeli (quantity)
  totalPrice    Int      // price * amount
  paymentMethod String   @default("CASH") // CASH, QRIS, DANA, SHOPEEPAY
  paymentProof  String?  // URL bukti transfer QRIS (Supabase Storage)
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  externalRef   String?  // referensi payment gateway mock
  note          String?
  pointsEarned  Int      @default(0) // poin loyalty yang didapat dari transaksi ini
  droppedCardId String?  // ID kartu yang didapat dari transaksi ini (jika ada)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  droppedCard Card?    @relation(fields: [droppedCardId], references: [id])
}

// ─── QRIS SETTINGS ──────────────────────────
// Singleton: hanya 1 row, berisi gambar QRIS toko
model QrisSettings {
  id        String   @id @default("qris-main")
  imageUrl  String   // URL gambar QRIS toko (Supabase Storage)
  label     String   @default("QRIS Kenzy Store") // nama yang ditampilkan
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── NEWS / PENGUMUMAN ──────────────────────
// Berita / pengumuman toko, ditampilkan sebagai banner
model News {
  id          String   @id @default(uuid())
  title       String           // Judul berita
  content     String           // Isi berita
  imageUrl    String?          // URL gambar banner (opsional, Supabase Storage)
  isPublished Boolean  @default(false) // Draft / Published
  isPinned    Boolean  @default(false) // Pin di atas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── REFRESH TOKEN ───────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PASSWORD RESET TOKEN ───────────────────
// Token untuk fitur lupa password (reset password via email)
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique   // Token unik (crypto random hex)
  expiresAt DateTime            // Kadaluarsa token (default: 15 menit)
  isUsed    Boolean  @default(false) // Sudah dipakai?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── FLASH SALE ─────────────────────────────
// Promo flash sale dengan hitungan mundur
// Admin bisa atur produk mana, diskon berapa %, dan kapan mulai/berakhir
model FlashSale {
  id              String   @id @default(uuid())
  title           String           // Judul promo, e.g. "Flash Sale Weekend!"
  description     String?          // Deskripsi opsional
  discountPercent Int              // Persentase diskon (1-100)
  productId       String?          // Produk spesifik (null = semua produk)
  category        String?          // Kategori spesifik (null = semua kategori)
  startAt         DateTime         // Waktu mulai flash sale
  endAt           DateTime         // Waktu berakhir flash sale
  isActive        Boolean  @default(true) // Toggle aktif/nonaktif manual
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product?   @relation(fields: [productId], references: [id])
  blastLogs BlastLog[] // Log pengiriman WA blast
}

// ─── LOYALTY POINTS ─────────────────────────
// Saldo poin per user (1 row per user, seperti wallet)
model LoyaltyPoints {
  id           String   @id @default(uuid())
  userId       String   @unique
  totalPoints  Int      @default(0) // Total poin yang pernah didapat
  currentPoints Int     @default(0) // Poin yang tersedia (belum ditukar)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── POINT REDEMPTION ───────────────────────
// Log setiap kali user menukar poin untuk diskon
model PointRedemption {
  id             String   @id @default(uuid())
  userId         String
  pointsUsed     Int              // Jumlah poin yang dipakai
  discountAmount Int              // Nilai diskon dalam rupiah
  discountCode   String   @unique // Kode unik untuk klaim diskon
  isUsed         Boolean  @default(false) // Sudah dipakai di transaksi?
  expiresAt      DateTime         // Kadaluarsa kode diskon
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── LOYALTY CONFIG ─────────────────────────
// Singleton: pengaturan global sistem poin (admin)
model LoyaltyConfig {
  id              String   @id @default("loyalty-config")
  pointsPerThousand Int    @default(1)   // Poin per Rp1.000 belanja
  pointValue      Int      @default(100) // 1 poin = Rp berapa
  minRedeemPoints Int      @default(100) // Minimum poin untuk redeem
  redeemExpiryDays Int     @default(30)  // Hari kadaluarsa kode diskon
  isActive        Boolean  @default(true) // Toggle sistem poin
  updatedAt       DateTime @updatedAt
}

// ─── MISSION LOG ────────────────────────────
// Log misi harian (daily share mission)
// Satu user hanya bisa klaim 1x per hari (unique userId + missionDate)
model MissionLog {
  id          String   @id @default(uuid())
  userId      String
  missionDate String              // Tanggal WIB format "YYYY-MM-DD"
  channel     String              // whatsapp, instagram, tiktok, copy
  points      Int      @default(10)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionDate]) // 1x per hari per user
}

// ─── BLAST LOG ──────────────────────────────
// Log pengiriman pesan WA blast ke user
// Bisa terkait flash sale ATAU custom blast dari admin
// Tracking status: pending → sent / failed
model BlastLog {
  id          String    @id @default(uuid())
  flashSaleId String?             // Optional — null jika custom blast
  waBlastId   String?             // Optional — null jika flash sale blast
  userId      String
  phone       String              // Nomor WA tujuan (format 62xxx)
  status      String    @default("pending") // pending | sent | failed
  sentAt      DateTime?           // Waktu berhasil terkirim
  errorMsg    String?             // Pesan error jika gagal
  createdAt   DateTime  @default(now())

  flashSale FlashSale? @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  waBlast   WaBlast?   @relation(fields: [waBlastId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([flashSaleId])
  @@index([waBlastId])
  @@index([userId])
}

// ─── WA BLAST (Custom Admin Blast) ──────────
// Kampanye blast WA custom dari admin (bukan terkait flash sale)
// Admin bisa pilih kirim ke semua user atau user tertentu
model WaBlast {
  id         String   @id @default(uuid())
  message    String              // Isi pesan WA (caption jika ada gambar)
  imageUrl   String?             // URL gambar (Supabase Storage), opsional
  targetType String              // "all" | "selected"
  totalSent  Int      @default(0) // Total pesan yang dikirim
  adminId    String              // Admin yang mengirim
  createdAt  DateTime @default(now())

  admin     User       @relation(fields: [adminId], references: [id])
  blastLogs BlastLog[]
}

// ─── PUSH SUBSCRIPTION ─────────────────────
// Simpan subscription browser push notification per user
// Satu user bisa punya banyak subscription (multi-device)
model PushSubscription {
  id           String   @id @default(uuid())
  userId       String
  endpoint     String   @unique // Endpoint unik dari browser
  subscription String   // Full subscription JSON (endpoint + keys)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── NOTIFICATION ───────────────────────────
// Simpan log notifikasi in-app untuk user
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // "order_status" | "points" | "flash_sale" | "announcement"
  data      String?  // JSON string untuk data tambahan (url, targetId, dll)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ─── CARD (Kartu Kolektibel) ────────────────
// Pool kartu yang bisa didapatkan user saat top-up berhasil
model Card {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String
  rarity      Rarity   @default(COMMON)
  createdAt   DateTime @default(now())

  userCards     UserCard[]
  transactions Transaction[]  // Transaksi yang mendrop kartu ini
  wishlists    Wishlist[]     // User yang menginginkan kartu ini
  offeredIn    TradeOffer[] @relation("OfferedCard")  // Trade yang menawarkan kartu ini
  wantedIn     TradeOffer[] @relation("WantedCard")   // Trade yang meminta kartu ini
}

// ─── USER CARD (Kartu yang dimiliki user) ───
// Junction table: 1 user hanya bisa punya 1 copy tiap kartu
model UserCard {
  id         String   @id @default(cuid())
  userId     String
  cardId     String
  obtainedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       Card     @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
}

// ─── GAMER PROFILE ──────────────────────────
// Profil akun game user (1 akun per game)
// Digunakan untuk auto-fill form order
model GamerProfile {
  id           String   @id @default(cuid())
  userId       String
  gameId       String   // ID game di sistem (misal: "mobile-legends")
  gameName     String
  gameIcon     String?
  inGameUserId String   // User ID / UID in-game
  serverOrZone String?  // Server ID, opsional
  nickname     String?  // Nickname opsional
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

// ─── RARITY ENUM ────────────────────────────
enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// ─── WISHLIST (Kartu yang diinginkan user) ──
// User bisa bookmark kartu yang mereka inginkan untuk trading
model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([cardId])
}

// ─── TRADE OFFER (Penawaran tukar kartu) ────
// User bisa menawarkan kartu yang dimiliki untuk ditukar dengan kartu lain
model TradeOffer {
  id                  String      @id @default(uuid())
  offererId           String
  offeredCardId       String
  wantedCardId        String
  status              TradeStatus @default(OPEN)
  matchedUserId       String?
  confirmedByOfferer  Boolean     @default(false)
  confirmedByMatcher  Boolean     @default(false)
  expiresAt           DateTime
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  offerer     User  @relation("TradeOfferer", fields: [offererId], references: [id])
  matchedUser User? @relation("TradeMatched", fields: [matchedUserId], references: [id])
  offeredCard Card  @relation("OfferedCard", fields: [offeredCardId], references: [id])
  wantedCard  Card  @relation("WantedCard", fields: [wantedCardId], references: [id])

  @@index([offererId])
  @@index([status])
  @@index([offeredCardId])
  @@index([wantedCardId])
}

// ─── TRADE STATUS ENUM ──────────────────────
enum TradeStatus {
  OPEN
  MATCHED
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}
