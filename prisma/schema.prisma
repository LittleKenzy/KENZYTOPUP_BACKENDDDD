// ============================================
// Prisma Schema — Kenzy Store
// Database: SQLite (ringan untuk demo/dev)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String   @unique
  password  String   // bcrypt hashed
  role      String   @default("user") // "user" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  refreshTokens RefreshToken[]
}

// ─── PRODUCT ─────────────────────────────────
// category: GAME | EWALLET | PLN | PULSA | PAKET_DATA
model Product {
  id           String   @id @default(uuid())
  category     String   // GAME, EWALLET, PLN, PULSA, PAKET_DATA
  name         String
  description  String?
  denomination String   // nominal label, e.g. "86 Diamonds", "50.000"
  price        Int      // harga dalam rupiah (integer, no float)
  operatorCode String   // kode operator / publisher, e.g. "MLBB", "TELKOMSEL"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  transactions Transaction[]
}

// ─── TRANSACTION ─────────────────────────────
// status: PENDING | SUCCESS | FAILED
// paymentMethod: CASH | QRIS | DANA | SHOPEEPAY
model Transaction {
  id            String   @id @default(uuid())
  userId        String
  productId     String
  targetId      String   // ID game / no HP / no meter PLN
  amount        Int      // jumlah dibeli (quantity)
  totalPrice    Int      // price * amount
  paymentMethod String   @default("CASH") // CASH, QRIS, DANA, SHOPEEPAY
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  externalRef   String?  // referensi payment gateway mock
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ─── REFRESH TOKEN ───────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
